generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Merchant {
  address      String   @id
  name         String?
  creditScore  Int      @default(0)
  creditTier   Int      @default(0)
  scoreUpdated DateTime?
  registeredAt DateTime
  vaults       Vault[]
}

model Vault {
  address           String   @id
  merchant          Merchant @relation(fields: [merchantAddr], references: [address])
  merchantAddr      String
  targetAmount      BigInt
  totalRaised       BigInt   @default(0)
  totalRepaid       BigInt   @default(0)
  totalToRepay      BigInt   @default(0)
  interestRateBps   Int
  durationSeconds   Int
  numTranches       Int
  tranchesReleased  Int      @default(0)
  state             String   @default("fundraising")
  seniorFunded      BigInt   @default(0)
  poolFunded        BigInt   @default(0)
  userFunded        BigInt   @default(0)
  totalSeniorRepaid BigInt   @default(0)
  totalPoolRepaid   BigInt   @default(0)
  nextPaymentDue    DateTime?
  lateFeeBps        Int      @default(0)
  totalLateFees     BigInt   @default(0)
  gracePeriodDays   Int      @default(7)
  createdAt         DateTime
  activatedAt       DateTime?
  investments       Investment[]
  events            VaultEvent[]
  milestones        MilestoneRecord[]
}

model Investment {
  id             String   @id @default(uuid())
  vault          Vault    @relation(fields: [vaultAddr], references: [address])
  vaultAddr      String
  investor       String
  amount         BigInt
  claimedReturns BigInt   @default(0)
  investedAt     DateTime
}

model VaultEvent {
  id          String   @id @default(uuid())
  vault       Vault?   @relation(fields: [vaultAddr], references: [address])
  vaultAddr   String?
  eventType   String
  data        Json
  blockNumber BigInt
  txHash      String
  logIndex    Int      @default(0)
  timestamp   DateTime

  @@unique([txHash, logIndex])
  @@index([vaultAddr, eventType])
  @@index([eventType])
}

model IndexerState {
  id        String   @id @default("singleton")
  lastBlock BigInt   @default(0)
  updatedAt DateTime @updatedAt
}

model MilestoneRecord {
  id            String    @id @default(uuid())
  vault         Vault     @relation(fields: [vaultAddr], references: [address])
  vaultAddr     String
  milestoneId   Int
  status        String    @default("pending")
  evidenceHash  String?
  approvalCount Int       @default(0)
  submittedAt   DateTime?
  approvedAt    DateTime?

  @@unique([vaultAddr, milestoneId])
}

model Pool {
  address               String  @id
  admin                 String
  isAlpha               Boolean
  totalDeposits         BigInt  @default(0)
  totalAllocated        BigInt  @default(0)
  maxAllocationPerVault BigInt
  paused                Boolean @default(false)
}

model ApiKey {
  id        String   @id @default(uuid())
  key       String   @unique
  name      String
  tier      String   @default("free") // "free" | "paid"
  rateLimit Int      @default(100)
  createdAt DateTime @default(now())
  active    Boolean  @default(true)
}

model WebhookEndpoint {
  id         String             @id @default(uuid())
  url        String
  secret     String
  events     String[]           // e.g. ["VaultCreated", "RepaymentProcessed"]
  active     Boolean            @default(true)
  createdAt  DateTime           @default(now())
  deliveries WebhookDelivery[]
}

model WebhookDelivery {
  id          String           @id @default(uuid())
  endpoint    WebhookEndpoint  @relation(fields: [endpointId], references: [id])
  endpointId  String
  eventType   String
  payload     Json
  status      String           @default("pending") // pending | delivered | failed
  statusCode  Int?
  attempts    Int              @default(0)
  nextRetryAt DateTime?
  lastError   String?
  createdAt   DateTime         @default(now())
  deliveredAt DateTime?

  @@index([endpointId, status])
  @@index([status, nextRetryAt])
}

model OraclePayment {
  id          String    @id @default(uuid())
  from        String
  to          String
  vault       String
  amount      BigInt
  nonce       BigInt
  deadline    BigInt
  paymentId   String
  status      String    @default("pending") // pending | submitted | confirmed | failed | expired
  txHash      String?
  error       String?
  attempts    Int       @default(0)
  nextRetryAt DateTime?
  createdAt   DateTime  @default(now())
  processedAt DateTime?

  @@index([status])
  @@unique([from, nonce])
}

model WaitlistEntry {
  id            String   @id @default(uuid())
  email         String   @unique
  walletAddress String?
  createdAt     DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// Solana — Agent Credit System
// ─────────────────────────────────────────────────────────────────────────────

/// Mirrors on-chain AgentWallet PDA state (keeper-synced every 2s)
model SolanaAgentWallet {
  agentPubkey      String   @id
  ownerPubkey      String
  ownerType        String   @default("eoa") // "eoa" | "multisig"
  pendingOwner     String?
  agentType        Int      @default(0)     // 0 = Trader, 1 = Service, 2 = Hybrid
  creditLevel      Int      @default(0)
  creditDrawn      BigInt   @default(0)
  creditLimit      BigInt   @default(0)
  totalDebt        BigInt   @default(0)
  collateralShares BigInt   @default(0)
  healthFactorBps  Int      @default(10000)
  dailySpendLimit  BigInt   @default(0)
  isFrozen         Boolean  @default(false)
  isLiquidating    Boolean  @default(false)
  totalTrades      BigInt   @default(0)
  totalVolume      BigInt   @default(0)
  totalRepaid      BigInt   @default(0)
  lastHealthCheck  DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  trades           SolanaAgentTrade[]
  healthSnapshots  HealthSnapshot[]
  kyaVerifications KyaVerification[]
  scoreSnapshots   ScoreSnapshot[]

  @@index([healthFactorBps])
  @@index([creditDrawn])
  @@index([totalDebt])
  @@index([isFrozen])
}

/// Individual trade records emitted by execute_trade events
model SolanaAgentTrade {
  id           String             @id @default(uuid())
  agentPubkey  String
  wallet       SolanaAgentWallet  @relation(fields: [agentPubkey], references: [agentPubkey])
  venue        String
  amount       BigInt
  direction    String             // "buy" | "sell"
  txSignature  String             @unique
  executedAt   DateTime
  status       String             @default("confirmed") // "pending" | "confirmed" | "failed"

  @@index([agentPubkey])
  @@index([executedAt])
  @@index([status])
}

/// Periodic health factor snapshots stored by the keeper
model HealthSnapshot {
  id              String             @id @default(uuid())
  agentPubkey     String
  wallet          SolanaAgentWallet  @relation(fields: [agentPubkey], references: [agentPubkey])
  healthFactorBps Int
  creditDrawn     BigInt
  totalDebt       BigInt
  walletUsdc      BigInt
  collateralValue BigInt
  snapshotAt      DateTime           @default(now())

  @@index([agentPubkey, snapshotAt])
}

/// Daily credit score snapshots with component breakdown
model ScoreSnapshot {
  id          String             @id @default(uuid())
  agentPubkey String
  wallet      SolanaAgentWallet  @relation(fields: [agentPubkey], references: [agentPubkey])
  score           Int
  level           Int
  components      Json               // { repayment, profit, behavior, usage, age }
  attestationHash String?            // keccak256(agent, score, level, timestamp) — stored on-chain
  snapshotAt      DateTime           @default(now())

  @@index([agentPubkey, snapshotAt])
}

/// KYA verification records (basic + enhanced)
model KyaVerification {
  id          String             @id @default(uuid())
  agentPubkey String
  wallet      SolanaAgentWallet? @relation(fields: [agentPubkey], references: [agentPubkey])
  tier        Int                // 1 = basic, 2 = enhanced
  method      String             // "auto" | "sumsub"
  status      String             @default("pending") // pending | approved | rejected
  reason      String?
  sumsubRef   String?
  verifiedAt  DateTime?
  createdAt   DateTime           @default(now())

  @@index([agentPubkey])
}

/// Whitelisted trading venues (mirrors on-chain WhitelistedVenue)
model SolanaVenueWhitelist {
  venuePubkey String   @id
  name        String?
  isActive    Boolean  @default(true)
  addedAt     DateTime @default(now())
}

/// Insurance fund snapshot (read from on-chain VaultConfig)
model InsuranceFund {
  id        String   @id @default("singleton")
  balance   BigInt   @default(0)
  updatedAt DateTime @updatedAt
}

/// Parsed Anchor events from all 5 programs
model SolanaEvent {
  id          String   @id @default(uuid())
  eventType   String
  data        Json
  txSignature String
  slot        Int
  indexedAt   DateTime @default(now())

  @@unique([txSignature, eventType])
  @@index([eventType])
  @@index([slot])
}

/// Faucet rate limiting — one row per recipient address
model FaucetMint {
  id          String   @id @default(uuid())
  recipient   String   @unique
  lastMintAt  DateTime @default(now())
  totalMinted Int      @default(0)
}

/// Tracks the last indexed transaction signature per program
model SolanaIndexerState {
  id            String   @id
  lastSignature String?
  updatedAt     DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// Credit Bureau (Phase 2)
// ─────────────────────────────────────────────────────────────────────────────

/// Tracks credit request lifecycle (pending → approved → rejected/expired)
model CreditRequest {
  id              String   @id @default(uuid())
  agentPubkey     String
  amount          BigInt               // requested amount in USDC base units
  creditLevel     Int
  status          String   @default("pending") // "pending" | "approved" | "rejected" | "expired"
  reason          String?              // rejection/expiry reason
  txSignature     String?              // on-chain tx if approved
  requestedAt     DateTime @default(now())
  resolvedAt      DateTime?

  @@index([agentPubkey, requestedAt])
  @@index([status])
}

/// Logs every credit inquiry — who queried whose credit and when
model CreditInquiry {
  id            String   @id @default(uuid())
  agentPubkey   String               // agent whose credit was queried
  requesterKey  String               // API key ID that made the request
  inquiryType   String               // "score" | "report" | "history"
  createdAt     DateTime @default(now())

  @@index([agentPubkey, createdAt])
  @@index([requesterKey])
}

/// Legal credit agreement for L3-L4 credit
model LegalAgreement {
  id              String   @id @default(uuid())
  agentPubkey     String
  agreementHash   String               // sha256 of the agreement document
  creditLevel     Int                  // level this agreement covers (3 or 4)
  status          String   @default("pending") // "pending" | "signed" | "expired"
  onChainHash     String?              // hash submitted on-chain via sign_legal_agreement
  txSignature     String?              // Solana tx that recorded the signature
  signedAt        DateTime?
  createdAt       DateTime @default(now())

  @@index([agentPubkey])
  @@index([status])
}
