{
  "name": "krexa-solana-programs",
  "version": "0.1.0",
  "description": "Krexa AI-agent credit protocol — Solana programs",
  "scripts": {
    "build": "anchor build",
    "test": "anchor test",
    "test:local": "anchor test --skip-local-validator",
    "deploy:devnet": "bash scripts/deploy-devnet.sh",
    "init:devnet": "npx ts-node --esm scripts/init-devnet.ts",
    "seed:devnet": "npx ts-node --esm scripts/seed-devnet.ts",
    "keys:list": "anchor keys list",
    "keys:sync": "anchor keys sync",
    "idl:build": "anchor build --idl target/idl",
    "lint": "cargo clippy -- -D warnings",
    "fmt": "cargo fmt --all"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.4",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.6",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.2",
    "bn.js": "^5.2.1",
    "chai": "^4.5.0",
    "mocha": "^10.8.2",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
