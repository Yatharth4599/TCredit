{
  "name": "@krexa/x402-middleware",
  "version": "0.1.0",
  "description": "One-line Express middleware for merchants to accept x402 payments via Krexa",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["krexa", "x402", "payment", "express", "middleware", "usdc", "ai-agent"],
  "license": "MIT",
  "dependencies": {
    "@krexa/sdk": "file:../sdk"
  },
  "peerDependencies": {
    "express": ">=4.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.0"
  }
}
