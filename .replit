modules = ["nodejs-20", "web", "python-3.12"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
BASE_RPC_URL = "https://sepolia.base.org"
CHAIN_ID = "84532"
AGENT_REGISTRY_ADDRESS = "0xAEa7C5CCACebB1423b163b765d3214752f1496A4"
PAYMENT_ROUTER_ADDRESS = "0xf8A5ED433222dFfb9514637243C3599cCE87f977"
VAULT_FACTORY_ADDRESS = "0xf8fDa17F877dEFFCD80784E0465F33d585644360"
SENIOR_POOL_ADDRESS = "0xDf980d0734b00888e4Ac350027515B4D6E473bBa"
GENERAL_POOL_ADDRESS = "0x7E7D8082572C0AD2f51074D272A501180Db06Fb2"
MILESTONE_REGISTRY_ADDRESS = "0x48a471eEB88f84a867bEBC0f6DFF848660BC8c84"
USDC_ADDRESS = "0x036CbD53842c5426634e7929541eC2318f3dCF7e"
PORT = "3001"
NODE_ENV = "development"
VITE_API_URL = "/api"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && npm run dev"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3001
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 5000

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd backend && npm run build && node dist/index.js & cd frontend && npm run preview -- --host 0.0.0.0 --port 5000"]
build = ["bash", "-c", "cd frontend && npm install && npm run build"]
