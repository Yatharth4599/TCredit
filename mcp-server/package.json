{
  "name": "@krexa/mcp",
  "version": "0.1.0",
  "description": "MCP server exposing Krexa agent credit tools for any LLM",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "krexa-mcp": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "krexa",
    "mcp",
    "ai-agent",
    "credit",
    "solana",
    "usdc"
  ],
  "license": "MIT",
  "dependencies": {
    "@krexa/sdk": "file:../sdk",
    "@modelcontextprotocol/sdk": "^1.10.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "path-to-regexp": "^8.4.1"
  }
}
