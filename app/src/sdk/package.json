{
  "name": "@krexa/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Krexa protocol — AI agent credit on Solana",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./transactions": {
      "import": "./dist/transactions.js",
      "types": "./dist/transactions.d.ts"
    },
    "./pda": {
      "import": "./dist/pda.js",
      "types": "./dist/pda.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./utils": {
      "import": "./dist/utils.js",
      "types": "./dist/utils.d.ts"
    },
    "./validation": {
      "import": "./dist/validation.js",
      "types": "./dist/validation.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "krexa",
    "solana",
    "defi",
    "credit",
    "ai-agent",
    "sdk"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Yatharth4599/TCredit"
  },
  "peerDependencies": {
    "@coral-xyz/anchor": ">=0.29.0",
    "@solana/web3.js": ">=1.90.0",
    "bn.js": ">=5.0.0"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/web3.js": "^1.98.4",
    "@types/bn.js": "^5.2.0",
    "bn.js": "^5.2.3",
    "typescript": "~5.9.3"
  }
}
